# Binance Futures Testnet API Configuration
# =========================================
# 1. Go to https://testnet.binancefuture.com/
# 2. Generate API keys under API Management
# 3. Copy your keys below (testnet only - never use production keys!)
#
# The testnet provides 3000 USDT of fake funds by default.

API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Optional: Override the default Testnet URL (only if needed)
# TESTNET_URL=https://testnet.binancefuture.com
